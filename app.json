{
  "expo": {
    "name": "Hidden Plate",
    "slug": "hidden_plate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/hiddenplatelogo.png",
    "scheme": [
      "hiddenplate",
      "appwrite-callback-69fe8b7f003e6deb2878"
    ],
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hiddenplate.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.hiddenplate.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#BB1A1A",
        "foregroundImage": "./assets/images/adaptive-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAxvvfQihUIhsnm12lZp5L2FEd1qsRPMk4"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#C81316",
          "dark": {
            "backgroundColor": "#C81316"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Hidden Plate needs access to your photos so you can add images to your restaurant reviews."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Hidden Plate uses your location to show restaurants near you."
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#0A0A0A"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "hidden-plate"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c00df0cb-9ec9-4786-98bb-bfb96d0912ec"
      }
    },
    "owner": "hiddenplateja"
  }
}
